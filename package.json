{
  "name": "aayush-language",
  "displayName": "Aayush Language",
  "description": "Nepali chat-style programming language support for .aayush files.",
  "version": "0.0.7",
  "publisher": "aayush",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayushshah/aayush-language.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:aayush.runFile"
  ],
  "main": "./extension.js",
  "bin": {
    "aayush": "./bin/aayush.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "aayush",
        "aliases": [
          "Aayush",
          "aayush"
        ],
        "extensions": [
          ".aayush"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aayush",
        "scopeName": "source.aayush",
        "path": "./syntaxes/aayush.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "aayush.runFile",
        "title": "Aayush: Run File"
      }
    ],
    "iconThemes": [
      {
        "id": "aayush-icons",
        "label": "Aayush Icons",
        "path": "./icons/aayush-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "run": "node bin/aayush.js run",
    "test": "node bin/aayush.js run examples/final_check.aayush",
    "check": "node -c bin/aayush.js && node bin/aayush.js run examples/final_check.aayush",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0",
    "typescript": "^6.0.3"
  }
}
