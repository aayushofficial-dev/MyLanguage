{
  "name": "aayush-language",
  "displayName": "Aayush Language",
  "description": "Nepali chat-style programming language support for .aayush files.",
  "version": "0.0.6",
  "publisher": "aayush",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aayushshah/aayush-language.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:aayush.runFile"
  ],
  "main": "./extension.js",
  "bin": {
    "aayush": "./bin/aayush.js"
  },
  "contributes": {
    "languages": [{
      "id": "aayush",
      "aliases": ["Aayush", "aayush"],
      "extensions": [".aayush"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "aayush",
      "scopeName": "source.aayush",
      "path": "./syntaxes/aayush.tmLanguage.json"
    }],
    "commands": [{
      "command": "aayush.runFile",
      "title": "Aayush: Run File"
    }],
    "iconThemes": [{
      "id": "aayush-icons",
      "label": "Aayush Icons",
      "path": "./icons/aayush-icon-theme.json"
    }]
  }
}
